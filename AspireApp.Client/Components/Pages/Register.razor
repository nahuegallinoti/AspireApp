@page "/register"
@attribute [AllowAnonymous]

<PageTitle>Create account</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1>Create account</h1>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger" role="alert">
                @foreach (var line in Error.Split("; "))
                {
                    <div>@line</div>
                }
            </div>
        }

        <form method="post" action="/auth/register" class="vstack gap-3">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div>
                <label for="email" class="form-label">Email</label>
                <input id="email" name="email" type="email" required autocomplete="email" class="form-control" />
            </div>
            <div class="row">
                <div class="col">
                    <label for="name" class="form-label">First name</label>
                    <input id="name" name="name" type="text" required autocomplete="given-name" class="form-control" />
                </div>
                <div class="col">
                    <label for="surname" class="form-label">Last name</label>
                    <input id="surname" name="surname" type="text" required autocomplete="family-name" class="form-control" />
                </div>
            </div>
            <div>
                <label for="password" class="form-label">Password</label>
                <input id="password" name="password" type="password" required minlength="8" autocomplete="new-password" class="form-control" />
                <div class="form-text">Minimum 8 characters.</div>
            </div>
            <button type="submit" class="btn btn-primary">Create account</button>
        </form>

        <hr />
        <p class="text-muted small">
            Already have an account?
            <a href="/login?returnUrl=@Uri.EscapeDataString(ReturnUrl ?? "/")">Sign in</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
}
