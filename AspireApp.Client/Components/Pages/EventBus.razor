@page "/eventbus"
@attribute [Authorize]

<PageTitle>Event bus</PageTitle>

<h1>Publish event</h1>
<p class="text-muted">
    Sends a message to the <code>demo</code> topic on the configured broker
    (RabbitMQ routing key or Kafka topic, depending on the EventBus provider).
</p>

<div class="row">
    <div class="col-lg-6">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                @foreach (var error in errorMessage.Split("; "))
                {
                    <div>@error</div>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(responseMessage))
        {
            <div class="alert alert-success">@responseMessage</div>
        }

        <EditForm Model="@Model" OnValidSubmit="SendMessage" FormName="messageForm" class="vstack gap-3">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div>
                <label for="message" class="form-label">Message</label>
                <InputText id="message" @bind-Value="Model.Message" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary align-self-start">Send</button>
        </EditForm>
    </div>
</div>
