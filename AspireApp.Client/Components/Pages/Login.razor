@page "/login"
@using Microsoft.Extensions.Options
@using AspireApp.Client.Authentication
@inject IOptions<GoogleClientOptions> GoogleOptions
@attribute [AllowAnonymous]

<PageTitle>Sign in</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1>Sign in</h1>
        <p class="text-muted">Use your AspireApp account to continue.</p>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger" role="alert">
                @foreach (var line in Error.Split("; "))
                {
                    <div>@line</div>
                }
            </div>
        }

        <form method="post" action="/auth/login" class="vstack gap-3">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div>
                <label for="email" class="form-label">Email</label>
                <input id="email" name="email" type="email" required autocomplete="username" class="form-control" />
            </div>
            <div>
                <label for="password" class="form-label">Password</label>
                <input id="password" name="password" type="password" required autocomplete="current-password" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Sign in</button>
        </form>

        @if (GoogleOptions.Value.Enabled)
        {
            <div class="text-center my-3 text-muted">or</div>
            <a class="btn btn-outline-secondary w-100"
               href="/auth/google/challenge?returnUrl=@Uri.EscapeDataString(ReturnUrl ?? "/")">
                <i class="bi bi-google me-2"></i> Continue with Google
            </a>
        }

        <hr />
        <p class="text-muted small">
            Don't have an account?
            <a href="/register?returnUrl=@Uri.EscapeDataString(ReturnUrl ?? "/")">Create one</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
}
