{
  "compileOnSave": true,
  "compilerOptions": {
    "noImplicitAny": true,
    "strict": true,
    "target": "ES6",
    "module": "es6",
    "sourceMap": true,
    "outDir": "wwwroot/js",
    "rootDir": "Typescript"
  },
  "include": [
    "Typescript/**/*"
  ],
  "exclude": [
    "node_modules",
    "wwwroot"
  ]
}